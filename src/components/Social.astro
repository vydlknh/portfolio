---
const { platform, username } = Astro.props;
---
<a href={`https://www.${platform}.com/${username}`} target=”_blank”>{platform}</a>

<style>
    a {
      padding: 0.5rem 1rem;
      color: white;
      background-color: #034C3C;
      text-decoration: none;
      border-radius: 10px;
    }
    a:hover {
      background-color: #033A2E;
    }
  </style>