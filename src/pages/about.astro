---
import '../styles/global.css';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import BaseLayout from '../layouts/BaseLayout.astro';


const pageTitle = "About Me";
const identity = {
	firstName: "Vy",
	hometown: "Hanoi, Vietnam",
	country: "Greencastle, Indiana",
	school: "DePauw University",
	majors: "Computer Science and Mathematics",
}
const skills = ["HTML", "CSS", "JavaScript", "TypeScript", "Java", "C++", "Python", "Astro", "React Native"]
const happy = true;
const finished = true;
const goal = 3;

const skillColor = "navy";
const fontWeight = "bold";
const textCase = "uppercase";
---

<BaseLayout pageTitle={pageTitle}>
	<p>Here are a few facts about me:</p>
		<ul>
		<li>My name is {identity.firstName}.</li>
		<li>I am a rising sophomore at {identity.school}, with a double major in {identity.majors}</li>
		<li>Originally from {identity.hometown}, I currently live in {identity.country}.</li>
		</ul>
		<p>My skills are:</p>
		<ul>
		{skills.map((skill) => <li class = "skill">{skill}</li>)}
		</ul>
		{happy && <p>I am happy to be learning Astro!</p>}

		{finished && <p>I finished this tutorial!</p>}

		{goal === 3 ? <p>My goal is to finish in 3 days.</p> : <p>My goal is not 3 days.</p>}
</BaseLayout>