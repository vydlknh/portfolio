---
import BaseLayout from '../layouts/BaseLayout.astro';
import PageLayout from '../layouts/PageLayout.astro';
import DarkLayout from '../layouts/DarkLayout.astro'
import Projects from '../components/Projects.astro';

const allPosts = await Astro.glob('../pages/projects/*.md');
const pageTitle = "Vy Do";

const identity = {
	hometown: "Hanoi, Vietnam",
	country: "Greencastle, Indiana",
	job: "undergraduate",
	role: "Front-End Web Intern",
	school: "DePauw University",
	majors: "Computer Science and Mathematics",
	prevExperience: "OnePay Vietnam",
	curExperience: "open to work",
	
}

const skills =[
	{icon: "https://upload.wikimedia.org/wikipedia/commons/thumb/3/38/HTML5_Badge.svg/800px-HTML5_Badge.svg.png", name: "HTML"},
	{icon: "https://upload.wikimedia.org/wikipedia/commons/thumb/6/62/CSS3_logo.svg/800px-CSS3_logo.svg.png", name: "CSS"},
	{icon: "https://upload.wikimedia.org/wikipedia/commons/thumb/6/6a/JavaScript-logo.png/800px-JavaScript-logo.png", name: "JavaScript"},
	{icon: "https://upload.wikimedia.org/wikipedia/commons/thumb/a/a7/React-icon.svg/2300px-React-icon.svg.png", name: "React"},
	{icon: "https://cdn-icons-png.flaticon.com/256/226/226777.png", name: "Java"},
	{icon: "https://upload.wikimedia.org/wikipedia/commons/thumb/1/18/ISO_C%2B%2B_Logo.svg/1822px-ISO_C%2B%2B_Logo.svg.png", name: "C++"},
	{icon: "https://upload.wikimedia.org/wikipedia/commons/thumb/c/c3/Python-logo-notext.svg/1869px-Python-logo-notext.svg.png", name: "Python"},
	{icon: "https://seeklogo.com/images/T/tailwind-css-logo-5AD4175897-seeklogo.com.png", name: "TailwindCSS"},
	{icon: "https://seeklogo.com/images/A/astro-icon-logo-44253BACEE-seeklogo.com.png", name: "Astro"},
	{icon: "https://git-scm.com/images/logos/downloads/Git-Icon-1788C.png", name: "Git"},
	{icon: "https://cdn-icons-png.flaticon.com/512/25/25231.png", name: "GitHub"},
]
---

<BaseLayout pageTitle={pageTitle}>
	<section id = "about"></section>
		<PageLayout sectionTitle="About">
			<div class = "row">
				<div id = "column-img" class = "column">
					<img src = "https://i.imgur.com/0E8a4Uz.jpg" alt="profile picture" style =" width: 25rem; border-radius: 50%;">
				</div>
				<div class = "column">
					<div class = "info">
						<ul>
							<li class="col-small">
								<h2>Who I am</h2>
								<span class="line"></span>
								<p>
									I am a {identity.job} at {identity.school}, with a double major in {identity.majors}.
									Originally from {identity.hometown}, I currently live in {identity.country}.
								</p>
							</li>
							<li class="col-small">
								<h2>Experience</h2>
								<span class="line"></span>
								<p>
									Previously, I worked as a {identity.role} at {identity.prevExperience}. Currently, I am {identity.curExperience}.
								</p>
							</li>
							<li class="col-large">
								<h2>Hobbies & interest</h2>
								<span class="line"></span>
								<p>
									Professionally, I am interested in machine learning and AI-driven game development, hence I often take online courses and do research on my own. 
									In my free time, I enjoy baking, hitting the gym, and playing video games :)
								</p>
							</li>
						</ul>
					</div>
				</div>
			</div>
		</PageLayout>
	</section>	

	<section id="projects">
		<DarkLayout sectionTitle="Projects">
			<div class = "project">
				{allPosts.map((post) => <Projects url={post.url} title={post.frontmatter.title} description={post.frontmatter.description} img = {post.frontmatter.image.url} alt = {post.frontmatter.image.alt}/>)}
			</div>
		</DarkLayout>
	</section>

	<section id="skills"></section>
		<PageLayout sectionTitle="Skills">
			
				<div class="gallery">
					{skills.map((skill) => 
						<div class ="gallery-col">
							<img src = `${skill.icon}` >
							<h3>{skill.name}</h3>
						</div>
					)}
				</div>
		</PageLayout>
	</section>
</BaseLayout>